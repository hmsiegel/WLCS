{
  "ConnectionStrings": {
    "Database": "Host=wlcs-db;Port=5432;Database=wlcs;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Json.JsonFormatter"
        }
      }
    ]
  },
  "Authorization": {
    "Permissions": {
      "CacheKeyPrefix": "permissions-",
      "CacheTimeInMinutes": 1
    }
  },
  "Modules": {
    "Users": {
      "Authorization": {
        "SameUser": {
          "CacheKeyPrefix": "same-user-",
          "CacheTimeInMinutes": 1
        }
      },
      "BackgroundJobs": {
        "ProcessInboxMessages": {
          "IntervalInSeconds": 10,
          "RetryCount": 1,
          "BatchSize": 5
        },
        "ProcessOutboxMessages": {
          "IntervalInSeconds": 10,
          "RetryCount": 1,
          "BatchSize": 5
        }
      }
    }
  }
}
